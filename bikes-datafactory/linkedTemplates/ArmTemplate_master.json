{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "bikes-datafactory"
		},
		"AzureDataLakeStorageForGithubData_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorageForGithubData'"
		},
		"AzureDataLakeStorageForGithubData_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://bikesdata.dfs.core.windows.net/"
		},
		"JsonFileForNameAndRelativeURL_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/datawithhasan/azure_end_to_end_pipeline/refs/heads/main/src/datafile_names_and_relative_urls.json"
		},
		"SourceForGithubServer_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "bikes-datafactory_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorageForGithubData_accountKey": {
						"value": "[parameters('AzureDataLakeStorageForGithubData_accountKey')]"
					},
					"AzureDataLakeStorageForGithubData_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorageForGithubData_properties_typeProperties_url')]"
					},
					"JsonFileForNameAndRelativeURL_properties_typeProperties_url": {
						"value": "[parameters('JsonFileForNameAndRelativeURL_properties_typeProperties_url')]"
					},
					"SourceForGithubServer_properties_typeProperties_url": {
						"value": "[parameters('SourceForGithubServer_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}